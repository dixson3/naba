.dolt/
*.db

# Skill runtime state + local config (bdplan; Surface Convention §6)
/.bdplan.local.json
/.state/

# Beads (bd doctor required exclusions)
.beads-credential-key
.beads/proxieddb/

# Skill runtime state + local config (yf-plan; Surface Convention §6)
/.yf/

/.worktrees/

# Skill runtime state + local config (yf-plan; Surface Convention §6)
/.beads/formulas/

# Playwright MCP scratch (screenshots, snapshots, console logs) — not source
.playwright-mcp/
