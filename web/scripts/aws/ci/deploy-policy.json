{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SiteBucketList",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::naba.ysapp.net"
    },
    {
      "Sid": "SiteObjectWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::naba.ysapp.net/*"
    },
    {
      "Sid": "CloudFrontInvalidate",
      "Effect": "Allow",
      "Action": "cloudfront:CreateInvalidation",
      "Resource": "arn:aws:cloudfront::REDACTED-ACCOUNT-ID:distribution/REDACTED-CF-DISTRIBUTION"
    }
  ]
}
